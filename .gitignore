.anchor
.DS_Store
target
**/*.rs.bk
node_modules
test-ledger
.yarn
.surfpool

# Node / TS
dist
.next
*.tsbuildinfo

# Web runtime config (secrets shouldn't live here, but keep it local-only)
web/.env.local
web/.env.*.local

# OS / editor
.vscode
.idea
*.swp

# Solana keypairs at root (program id keypair should live under target/)
wallet-*.json
admin-*.json

# Any keys directory (admin wallets, backup program keypairs, etc.)
keys/

# Build-time IDL copies are committed so downstream packages (web app
# deployed to Vercel, SDK consumers via git) can build without needing
# the Rust toolchain. `npm run sync-idl` regenerates them after a fresh
# `anchor build`.
# sdk/idl/*.json          # intentionally tracked
# sdk/src/idl-types.ts    # intentionally tracked
