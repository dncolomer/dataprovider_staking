# Copy to .env.local for each cluster you want the frontend to target.
# The web app bakes these into the static bundle at build time.

# ---- Localnet (default) ----
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8899
NEXT_PUBLIC_PROGRAM_ID=GyZKxaZaLZtKLes5JgJfEHZUBhrtuMgTNtuLiEU59Bqd
NEXT_PUBLIC_CLUSTER_LABEL=localnet

# ---- Devnet (when ready) ----
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_PROGRAM_ID=<DEVNET_PROGRAM_ID>
# NEXT_PUBLIC_CLUSTER_LABEL=devnet

# ---- Mainnet (not deployed yet) ----
# NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
# NEXT_PUBLIC_PROGRAM_ID=<MAINNET_PROGRAM_ID>
# NEXT_PUBLIC_CLUSTER_LABEL=mainnet-beta
