# Copy to .env.local for each cluster you want the frontend to target.
# The web app bakes these into the static bundle at build time.
#
# For Vercel: set these in the project Environment Variables page instead
# of committing them. Production should use the mainnet values below.

# ---- Mainnet (LIVE) ----
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_PROGRAM_ID=94Ja6Y8AuzmZHjQiyk2SzvoysnBr3F17nfHGrHm1idAZ
NEXT_PUBLIC_CLUSTER_LABEL=mainnet-beta

